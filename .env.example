APP_ENV=production

# Firebase
FIREBASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app/

# SMTP (required for OTP + notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Admin
ADMIN_USER=admin
ADMIN_PASS_HASH=
ADMIN_FORCE_PASSWORD_RESET=0
ADMIN_ENFORCE_HTTPS=true

# IMPORTANT for Railway:
# set this to a mounted volume path (recommended) like /data/admin_auth.json
# fallback path /tmp/admin_auth.json is ephemeral.
ADMIN_AUTH_STORE=/data/admin_auth.json

# Security / captcha
RECAPTCHA_SECRET_KEY=
RECAPTCHA_TEST_BYPASS=0
RECAPTCHA_TEST_BYPASS_TOKEN=local-recaptcha-bypass-token

# AI assistant (optional)
AI_CHAT_ENABLED=1
AI_CHAT_PROVIDER=openai
AI_CHAT_API_KEY=
AI_CHAT_MODEL=gpt-4.1-mini
AI_CHAT_API_URL=https://api.openai.com/v1/responses
AI_CHAT_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# WebSocket (optional realtime worker)
WS_SERVER_HOST=0.0.0.0
WS_SERVER_PORT=8081
WS_EVENT_LOG=/data/ws-events.log
WS_TOKEN_SECRET=
WS_TOKEN_TTL_SECONDS=3600

# Uploads / retention
INQUIRY_UPLOAD_DIR=/data/inquiry_uploads
RETENTION_ENABLED=true
RETENTION_CUSTOMER_PII_DAYS=365

